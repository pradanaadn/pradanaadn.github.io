---
import { Image } from "astro:assets";
import me from "../../public/me.png";
import {getPath} from  "../utils.tsx";

const summary = `Results-driven Machine Learning Engineer with 1 year of hands-on experience in developing 
scalable AI solutions. Proficient in Python, TensorFlow, PyTorch, and system architecture. 
Proven track record in optimizing models for high performance and efficiency. 
Passionate about continuous learning and innovation.`;

const education = [
  {
    school: "Udayana University",
    degree: "Bachelor Of Engineering in Electrical and Computer Engineering",
    period: "2020 - 2024",
    gpa: "3.97/4.0",
  },
];
---

<section
  id="aboutme"
  class="py-12 border-t border-[#ffffff10] text-[var(--white)]"
>
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">About me</h2>
    <h3 class="text-4xl md:text-5xl font-medium mb-8">
      Putu Gede Pradana Adnyana
    </h3>
    <div class="flex flex-col md:flex-row gap-8 items-start">
      <div class="flex-1 space-y-6">
        <p class="text-lg text-[var(--white-icon)] leading-relaxed">
          {summary}
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            type="button"
            href={getPath("/pdf/latest_resume.pdf")}
            target="_blank"
            class="inline-flex items-center gap-2 rounded-full border border-[var(--sec)]/35 bg-[var(--background)]/40 px-5 py-2.5 text-sm font-semibold text-[var(--sec)] transition hover:bg-[var(--sec)] hover:text-[var(--background)] focus:outline-none focus:ring-4 focus:ring-[var(--sec)]/30"
          >
            <!-- License: MIT. Made by michaelampr: https://github.com/michaelampr/jam -->
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 shrink-0 fill-current"
              aria-hidden="true"
              focusable="false"
              role="img"
            >
              <path
                d="M3 0h10a3 3 0 0 1 3 3v14a3 3 0 0 1-3 3H3a3 3 0 0 1-3-3V3a3 3 0 0 1 3-3zm1 7a1 1 0 1 0 0 2h8a1 1 0 0 0 0-2H4zm0 8a1 1 0 0 0 0 2h5a1 1 0 0 0 0-2H4zM4 3a1 1 0 1 0 0 2h8a1 1 0 0 0 0-2H4zm0 8a1 1 0 0 0 0 2h8a1 1 0 0 0 0-2H4z"
              ></path>
            </svg>
            Resume
          </a>
        </div>

        <div class="space-y-4 pt-2">
          <h4 class="text-xl font-medium text-[var(--white)]">Education</h4>
          <div class="divide-y divide-[var(--white-icon-tr)] border-t border-[var(--white-icon-tr)]">
            {
              education.map((edu) => (
                <div class="grid gap-3 py-4 sm:grid-cols-[1fr_auto] sm:items-start">
                  <div>
                    <h5 class="font-semibold text-[var(--white)]">{edu.school}</h5>
                    <p class="mt-1 text-sm leading-relaxed text-[var(--white-icon)]">
                      {edu.degree}
                    </p>
                  </div>

                  <div class="flex flex-col items-start gap-2 sm:items-end">
                    <span class="text-sm text-[var(--white-icon)]">{edu.period}</span>
                 
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <div class="w-full md:w-80 shrink-0">
        <div class="sticky top-8">
          <div
            class="aspect-square rounded-full overflow-hidden border-2 border-[var(--sec)]"
          >
            <Image
              src={me}
              alt="Putu Gede Pradana Adnyana"
              class="w-full h-full object-cover"
              width={320}
              height={320}
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
