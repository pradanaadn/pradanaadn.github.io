---
import ProjectList, { Project } from "../React/ProjectList.tsx";
import Waste from "../../public/projects/Waste.png";
import Trash from "../../public/projects/Trash.png";
import umeals from "../../public/projects/NutriMom.png";
import SafeFlood from "../../public/projects/SafeFlood.png";
import TemanWisata from "../../public/projects/TemanWisata.png";
const projects: Project[] = [
  {
  title: "Teman Wisata",
  year: "2025",
  image: TemanWisata as ImageMetadata,
  preview: "https://www.loom.com/share/cdd6c48daee044bd881ce7eb637770b5?t=52&sid=8773bf8d-214b-4633-b9cc-d3cb542e8a23",
  link: "https://github.com/TemanWisata",
  status: "Completed",
  description:
    "An intelligent, personalized travel recommendation platform engineered to optimize trip planning for tourists exploring major cities in Indonesia by eliminating decision fatigue.",
  stack: [
    "FastAPI",
    "TypeScript",
    "RecTools",
    "Kubernetes (K3s)",
    "Supabase",
    "Redis",
    "MLflow",
    "MinIO",
    "Prometheus",
    "Grafana",
    "Cloudflare"
  ],
  achievements: [
    "Implemented SASRec and BERT4Rec for next-item travel recommendations",
    "Deployed a cost-efficient MLOps stack on a single 4 vCPU, 4 GB VM with K3s",
    "Set up monitoring with Prometheus, Grafana, Loki, MinIO, and cert-manager"
  ]
},
  {
    title: "SafeFlood",
    year: "2025",
    image: SafeFlood as ImageMetadata,
    preview: "https://www.youtube.com/watch?v=nryf8y9dsJg", 
    link: "https://github.com/SafeFlood",
    status: "Completed", 
    description:
      "A web-based early warning system designed to predict floods in South Sulawesi using satellite data, aimed at minimizing infrastructure damage and social-economic loss.",
    stack: ["Python", "Google Earth Engine", "Docker", "Scikit-learn", "GitHub"], 
    achievements: [
      "Achieved 98% accuracy using the Random Forest model for flood prediction",
      "Developed a 'no-device' prediction solution utilizing satellite data instead of local hardware",
      "Integrated a comprehensive dashboard for weather forecasting and flood risk visualization",
    ],
  },
  {
    title: "Trash Object Detection",
    year: "2024",
    image: Trash as ImageMetadata,
    preview:
      "https://pitch.com/v/mangorenai-x6n96f/8d37c2f6-d584-4403-8c63-3ce5c4325ef7",
    link: "https://github.com/Magang-X-Cloud",
    status: "Completed",
    description:
      "AI-powered waste detection and monitoring solution for waste management. A hackathon project",
    stack: ["Python", "Streamlit", "YOLOv8", "Alibaba Cloud", "OpenCV"],
    achievements: [
      "Achieve 92% precision in waste objec detection",
      "Chatbot powered by Qwen-MAX",
      
    ],
  },
  {
    title: "Waste Classification",
    year: "2024",
    image: Waste as ImageMetadata,
    preview:
      "https://pitch.com/v/mangorenai-x6n96f/8d37c2f6-d584-4403-8c63-3ce5c4325ef7",
    link: "https://github.com/pradanaadn/trash-classification",
    status: "Completed",
    description: "An image classfication model for classify waste objects",
    stack: [
      "Python",
      "Gradio",
      "Pytorch",
      "Transfer Learning",
      "Training Pipeline",
      "Monitoring",
    ],
    achievements: [
      "Developing CNN based classification model",
      "Setup training pipeline and monitoring using github action and wandb",
      "Developing Gradio based web app for model deployment",
    ],
  },
  {
    title: "UmMeals",
    year: "2024",
    image: umeals as ImageMetadata,
    link: "https://github.com/Talenta-AI-2",
    preview:
      "https://www.linkedin.com/posts/pradanaadn_ummeals-deck-activity-7223282999407099904-g2PD?utm_source=share&utm_medium=member_desktop",
    status: "Completed",
    description:
      "Maternal and Child Nutrition Tracking App with stunting detection",
    stack: ["Python", "SQLAlchemy", "Azure AI", "Power BI", "Streamlit"],
    achievements: [
      "Top 6 finalist Microsoft Innovation Challenge 2024",
      "Personalized nutrition monitoring and chatbot",
      "Early stunting detection system",
    ],
  },
];
const sortedProjects = projects.sort((a, b) => {
  // Convert year strings to numbers and compare
  const yearA = parseInt(a.year || "0");
  const yearB = parseInt(b.year || "0");
  return yearB - yearA;
});
---

<section
  id="projects"
  class="py-12 border-t border-[#ffffff10] text-[var(--white)]"
>
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">Featured Projects</h2>
    <h3 class="text-4xl md:text-5xl font-medium mb-8">My Work</h3>
    <ProjectList projects={projects} />
  </div>
</section>
